<Window x:Class="DbUi.UI.Views.CreateIndexDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:DbUi.UI.ViewModels.Dialogs"
        xmlns:conv="clr-namespace:DbUi.UI.Converters"
        Title="New Index"
        Width="420" Height="480"
        MinWidth="360" MinHeight="360"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="{StaticResource BgPanelBrush}">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Index name -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="110" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Label Content="Index name:" VerticalAlignment="Center" />
            <TextBox Grid.Column="1"
                    Text="{Binding IndexName, UpdateSourceTrigger=PropertyChanged}"
                    VerticalContentAlignment="Center" />
        </Grid>

        <!-- Table name (read-only) -->
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="110" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Label Content="Table name:" VerticalAlignment="Center" />
            <TextBox Grid.Column="1"
                    Text="{Binding TableName}"
                    IsReadOnly="True"
                    IsReadOnlyCaretVisible="False"
                    Background="{StaticResource BgPanelBrush}"
                    VerticalContentAlignment="Center" />
        </Grid>

        <!-- Options -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="110,0,0,10">
            <CheckBox Content="Unique" IsChecked="{Binding IsUnique}" Margin="0,0,16,0" />
            <ComboBox ItemsSource="{Binding IndexTypes}"
                     SelectedItem="{Binding IndexType}"
                     Width="90" />
        </StackPanel>

        <Label Grid.Row="3" Content="Columns:" Margin="0,0,0,4" />

        <!-- Column list -->
        <Border Grid.Row="4" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
               Background="{StaticResource BgMainBrush}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding AvailableColumns}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <CheckBox Content="{Binding ColumnName}"
                                      IsChecked="{Binding IsSelected}"
                                      Margin="8,4" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- Error -->
        <TextBlock Grid.Row="5"
                  Text="{Binding ErrorMessage}"
                  Foreground="{StaticResource ErrorBrush}"
                  Visibility="{Binding ErrorMessage, Converter={StaticResource BoolToVis}}"
                  TextWrapping="Wrap"
                  Margin="0,8,0,0" />

        <!-- Buttons -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button Content="OK"
                    Command="{Binding OkCommand}"
                    IsDefault="True"
                    MinWidth="80" Margin="0,0,8,0" />
            <Button Content="Cancel"
                    Command="{Binding CancelCommand}"
                    IsCancel="True"
                    MinWidth="80" />
        </StackPanel>
    </Grid>
</Window>
