<Window x:Class="DbUi.UI.Views.CreateTriggerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:DbUi.UI.ViewModels.Dialogs"
        xmlns:conv="clr-namespace:DbUi.UI.Converters"
        Title="New Trigger"
        Width="620" Height="480"
        MinWidth="480" MinHeight="360"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="{StaticResource BgPanelBrush}">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Trigger name -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="110" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Label Content="Trigger name:" VerticalAlignment="Center" />
            <TextBox Grid.Column="1"
                    Text="{Binding TriggerName, UpdateSourceTrigger=PropertyChanged}"
                    VerticalContentAlignment="Center" />
        </Grid>

        <!-- Table name -->
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="110" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Label Content="Table name:" VerticalAlignment="Center" />
            <TextBox Grid.Column="1"
                    Text="{Binding TableName}"
                    IsReadOnly="True"
                    Background="{StaticResource BgPanelBrush}"
                    VerticalContentAlignment="Center" />
        </Grid>

        <!-- Event / Timing -->
        <Grid Grid.Row="2" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="110" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Label Content="Event:" VerticalAlignment="Center" />
            <ComboBox Grid.Column="1"
                     ItemsSource="{Binding Events}"
                     SelectedItem="{Binding Event}"
                     VerticalContentAlignment="Center" />
            <ComboBox Grid.Column="2"
                     ItemsSource="{Binding Timings}"
                     SelectedItem="{Binding Timing}"
                     Width="110" Margin="8,0,0,0" />
        </Grid>

        <Label Grid.Row="3" Content="Body:" Margin="0,0,0,4" />

        <!-- Body -->
        <Border Grid.Row="4" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                Background="{StaticResource BgMainBrush}">
            <TextBox Text="{Binding Body, UpdateSourceTrigger=PropertyChanged}"
                     AcceptsReturn="True"
                     AcceptsTab="True"
                     FontFamily="Cascadia Code, Consolas, Courier New"
                     FontSize="13"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     TextWrapping="NoWrap"
                     BorderThickness="0" />
        </Border>

        <!-- Error -->
        <TextBlock Grid.Row="5"
                  Text="{Binding ErrorMessage}"
                  Foreground="{StaticResource ErrorBrush}"
                  Visibility="{Binding ErrorMessage, Converter={StaticResource BoolToVis}}"
                  TextWrapping="Wrap"
                  Margin="0,8,0,0" />

        <!-- Buttons -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button Content="OK"
                    Command="{Binding OkCommand}"
                    IsDefault="True"
                    MinWidth="80" Margin="0,0,8,0" />
            <Button Content="Cancel"
                    Command="{Binding CancelCommand}"
                    IsCancel="True"
                    MinWidth="80" />
        </StackPanel>
    </Grid>
</Window>
