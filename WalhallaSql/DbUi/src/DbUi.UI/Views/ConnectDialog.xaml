<Window x:Class="DbUi.UI.Views.OpenDatabaseDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:DbUi.UI.ViewModels"
        xmlns:conv="clr-namespace:DbUi.UI.Converters"
        Title="Open Database"
        Width="420" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="{StaticResource BgPanelBrush}">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <Border Background="{StaticResource BgPanelBrush}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- In-Memory toggle -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Label Content="Mode:" VerticalAlignment="Center" />
            <CheckBox Grid.Column="1"
                      IsChecked="{Binding IsInMemory}"
                      Content="In-Memory"
                      VerticalAlignment="Center" />
        </Grid>

        <!-- Storage Path (visible when not in-memory) -->
        <Grid Grid.Row="1" Margin="0,0,0,10"
              Visibility="{Binding IsInMemory, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Label Content="Storage path:" VerticalAlignment="Center" />
            <TextBox Grid.Column="1" Text="{Binding StoragePath, UpdateSourceTrigger=PropertyChanged}" />
        </Grid>

        <!-- Error -->
        <TextBlock Grid.Row="2"
                   Text="{Binding ErrorMessage}"
                   Foreground="{StaticResource ErrorBrush}"
                   Visibility="{Binding ErrorMessage, Converter={StaticResource BoolToVis}}"
                   TextWrapping="Wrap" />

        <!-- Buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Open"
                    Command="{Binding OpenCommand}"
                    IsDefault="True"
                    MinWidth="80" Margin="0,0,8,0" />
            <Button Content="Cancel"
                    IsCancel="True"
                    MinWidth="80" />
        </StackPanel>
    </Grid>
    </Border>
</Window>
