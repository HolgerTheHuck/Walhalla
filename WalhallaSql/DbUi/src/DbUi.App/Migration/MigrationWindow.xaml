<Window x:Class="DbUi.App.Migration.MigrationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:DbUi.App.Migration"
        xmlns:conv="clr-namespace:DbUi.UI.Converters;assembly=DbUi.UI"
        Title="MSSQL → WalhallaSql Migration"
        Width="800" Height="650"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgPanelBrush}">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- MSSQL Source -->
        <GroupBox Grid.Row="0" Header="MSSQL Source" Padding="10" Margin="0,0,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="100" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Label Grid.Row="0" Grid.Column="0" Content="Server:" VerticalAlignment="Center" />
                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Server, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,10,5" />

                <Label Grid.Row="0" Grid.Column="2" Content="Database:" VerticalAlignment="Center" />
                <TextBox Grid.Row="0" Grid.Column="3" Text="{Binding SourceDatabase, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,5" />

                <Label Grid.Row="1" Grid.Column="0" Content="Auth:" VerticalAlignment="Center" />
                <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,5">
                    <RadioButton Content="Windows" IsChecked="{Binding UseWindowsAuth}" GroupName="Auth" Margin="0,0,10,0" />
                    <RadioButton Content="SQL Server" GroupName="Auth" Margin="0,0,0,0" />
                </StackPanel>

                <Label Grid.Row="1" Grid.Column="2" Content="Schema:" VerticalAlignment="Center" />
                <TextBox Grid.Row="1" Grid.Column="3" Text="{Binding SourceSchema, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,5" />

                <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="4" Orientation="Horizontal"
                            Visibility="{Binding UseWindowsAuth, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}">
                    <Label Content="User:" VerticalAlignment="Center" />
                    <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" Width="140" Margin="0,0,10,5" />
                    <Label Content="Password:" VerticalAlignment="Center" />
                    <PasswordBox x:Name="PasswordBox" Width="140" Margin="0,0,0,5" />
                </StackPanel>
            </Grid>
        </GroupBox>

        <!-- Target -->
        <GroupBox Grid.Row="1" Header="Target" Padding="10" Margin="0,0,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="100" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <CheckBox Grid.Row="0" Grid.Column="0" Content="In-Memory"
                          IsChecked="{Binding IsInMemory}" VerticalAlignment="Center" />

                <StackPanel Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="3" Orientation="Horizontal"
                            Visibility="{Binding IsInMemory, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}">
                    <Label Content="Path:" VerticalAlignment="Center" />
                    <TextBox Text="{Binding TargetPath, UpdateSourceTrigger=PropertyChanged}" Width="300" />
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="4" Orientation="Horizontal" Margin="0,5,0,0">
                    <Label Content="Batch size:" VerticalAlignment="Center" />
                    <TextBox Text="{Binding BatchSize, UpdateSourceTrigger=PropertyChanged}" Width="80" Margin="0,0,20,0" />
                    <CheckBox Content="Drop &amp; Recreate tables"
                              IsChecked="{Binding DropAndRecreate}" VerticalAlignment="Center" />
                </StackPanel>
            </Grid>
        </GroupBox>

        <!-- Table Selection + Results -->
        <Grid Grid.Row="2" Margin="0,0,0,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Table header with Select All -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,5">
                <Button Content="Load Schema" Command="{Binding LoadSchemaCommand}"
                        IsEnabled="{Binding IsLoadingSchema, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}"
                        Padding="8,3" Margin="0,0,10,0" />
                <Button Content="Select All" Command="{Binding SelectAllTablesCommand}"
                        Visibility="{Binding HasSchema, Converter={StaticResource BoolToVis}}"
                        Padding="8,3" />
                <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource ErrorBrush}"
                           VerticalAlignment="Center" Margin="10,0,0,0"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource BoolToVis}}" />
            </StackPanel>

            <!-- Tables Grid -->
            <DataGrid Grid.Row="1" ItemsSource="{Binding Tables}"
                      AutoGenerateColumns="False"
                      IsReadOnly="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      Visibility="{Binding HasSchema, Converter={StaticResource BoolToVis}}"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling">
                <DataGrid.Columns>
                    <DataGridCheckBoxColumn Header="Migrate" Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" Width="60" />
                    <DataGridTextColumn Header="Table" Binding="{Binding TableName}" Width="*" />
                    <DataGridTextColumn Header="Columns" Binding="{Binding ColumnCount}" Width="70" />
                    <DataGridTextColumn Header="PKs" Binding="{Binding PrimaryKeyCount}" Width="50" />
                    <DataGridTextColumn Header="Rows" Binding="{Binding RowCountDisplay}" Width="80" />
                </DataGrid.Columns>
            </DataGrid>

            <!-- Loading indicator -->
            <TextBlock Grid.Row="1" Text="Loading schema..."
                       Visibility="{Binding IsLoadingSchema, Converter={StaticResource BoolToVis}}"
                       Foreground="#9B9B9B" FontStyle="Italic" Margin="5" />

            <!-- Results header -->
            <TextBlock Grid.Row="2" Text="Results" FontWeight="SemiBold"
                       Visibility="{Binding IsCompleted, Converter={StaticResource BoolToVis}}"
                       Margin="0,5,0,5" />

            <!-- Results Grid -->
            <DataGrid Grid.Row="3" ItemsSource="{Binding TableResults}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      Visibility="{Binding IsCompleted, Converter={StaticResource BoolToVis}}"
                      MaxHeight="150"
                      VirtualizingPanel.IsVirtualizing="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Table" Binding="{Binding TableName}" Width="*" />
                    <DataGridTextColumn Header="Imported" Binding="{Binding ImportedRows, StringFormat=N0}" Width="80" />
                    <DataGridTextColumn Header="Source" Binding="{Binding SourceRows, StringFormat=N0}" Width="80" />
                    <DataGridTextColumn Header="Target" Binding="{Binding TargetRows, StringFormat=N0}" Width="80" />
                    <DataGridTextColumn Header="Duration" Binding="{Binding Duration, StringFormat=s\\.ff}" Width="70" />
                    <DataGridTextColumn Header="Status" Binding="{Binding Success}" Width="60" />
                    <DataGridTextColumn Header="Error" Binding="{Binding Error}" Width="200" />
                </DataGrid.Columns>
            </DataGrid>

            <!-- Log -->
            <Label Grid.Row="4" Content="Log:" Margin="0,5,0,0" Padding="0" />
            <TextBox Grid.Row="5" Text="{Binding LogText, Mode=OneWay}"
                     IsReadOnly="True"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     Background="#1E1E1E" Foreground="#DCDCDC"
                     FontFamily="Cascadia Code, Consolas, Courier New" FontSize="11"
                     BorderThickness="1" BorderBrush="#3F3F46"
                     TextWrapping="NoWrap" />
        </Grid>

        <!-- Buttons -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Migrate" Command="{Binding MigrateCommand}"
                    IsDefault="True" Padding="12,4" Margin="0,0,10,0"
                    Visibility="{Binding IsMigrating, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}" />
            <Button Content="Cancel" Command="{Binding CancelMigrationCommand}"
                    Padding="12,4" Margin="0,0,10,0"
                    Visibility="{Binding IsMigrating, Converter={StaticResource BoolToVis}}" />
            <Button Content="Close" IsCancel="True" Padding="12,4" Click="CloseButton_Click" />
        </StackPanel>
    </Grid>
</Window>
