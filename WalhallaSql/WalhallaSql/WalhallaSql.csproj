<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>net8.0;net9.0;net10.0</TargetFrameworks>
    <Nullable>enable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <RootNamespace>WalhallaSql</RootNamespace>
    <AssemblyName>WalhallaSql</AssemblyName>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <NoWarn>CS1591</NoWarn>
    <IsPackable>true</IsPackable>
    <PackageId>WalhallaSql</PackageId>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <Description>WalhallaSql embedded SQL database engine.</Description>
    <PackageTags>database;sql;embedded;sqlite;netstandard</PackageTags>
    <SignAssembly>true</SignAssembly>
    <AssemblyOriginatorKeyFile>$(MSBuildThisFileDirectory)..\walhalla.snk</AssemblyOriginatorKeyFile>
    <Version>1.0.1</Version>
  </PropertyGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="WalhallaSql.AdoNet, " />
    <InternalsVisibleTo Include="WalhallaSql.EfCore, " />
    <InternalsVisibleTo Include="WalhallaSql.Benchmarks, " />
    <InternalsVisibleTo Include="WalhallaSql.Tests, " />
    <InternalsVisibleTo Include="WalhallaSql.PgWire, " />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\VectorStore\Walhalla.Storage\Walhalla.Storage.csproj" />
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp" Version="4.5.0" />
    <PackageReference Include="Microsoft.CodeAnalysis.PublicApiAnalyzers" Version="3.3.4">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
  </ItemGroup>

  <ItemGroup>
    <AdditionalFiles Include="PublicAPI.Shipped.txt" />
    <AdditionalFiles Include="PublicAPI.Unshipped.txt" />
  </ItemGroup>


  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
  </ItemGroup>

</Project>
